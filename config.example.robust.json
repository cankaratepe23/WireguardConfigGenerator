// Robust Discord-only split tunnel.
//
// Instead of resolving Discord's Cloudflare-fronted apex domains (which sit behind
// anycast and can churn), this tunnels Cloudflare's full published IPv4 range. In the
// isolated bot netns the bot touches nothing else on Cloudflare, so this is safe and
// more resilient than DNS resolution.
//
// With IpSourceUrls covering Cloudflare, the Domains list below is largely redundant
// (kept as a belt-and-suspenders fallback). Voice (*.discord.media) is Google-hosted,
// so crt.sh is still required for it.
//
// To use: mount this file into the generator and point CONFIG_PATH at it (see
// docker-compose.example.yml). Comments and trailing commas are tolerated by the loader.
{
  "IpSourceUrls": [
    "https://www.cloudflare.com/ips-v4"
  ],
  "Domains": [
    "discord.com",
    "gateway.discord.gg",
    "cdn.discordapp.com"
  ],
  "CrtShSources": [
    "https://crt.sh/?q=discord.media&output=json&exclude=expired"
  ],
  "AlwaysInclude": [
    "10.66.66.1/32"
  ],
  "PadDnsResultsToSlash24": true
}
